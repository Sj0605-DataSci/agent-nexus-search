{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0",
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "category": "productivity",
  "permissions": [],
  "host_permissions": ["https://*.discoverminds.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Discover Minds",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "author": {
    "email": "teamdiscoverminds@gmail.com",
    "name": "Discover Minds Team",
    "url": "https://discoverminds.ai/team"
  },
  "homepage_url": "https://discoverminds.ai",
  "minimum_chrome_version": "88"
}
